{
  "id": "strongclaw-memory-v2",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "configPath": {
        "type": "string"
      },
      "command": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      },
      "autoRecall": {
        "type": "boolean"
      },
      "autoReflect": {
        "type": "boolean"
      },
      "recallMaxResults": {
        "type": "number",
        "minimum": 1,
        "maximum": 10
      },
      "timeoutMs": {
        "type": "number",
        "minimum": 1000,
        "maximum": 120000
      }
    },
    "required": [
      "configPath"
    ]
  }
}
