{
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "command": "__HOME__/.bun/bin/qmd",
      "includeDefaultMemory": true,
      "limits": {
        "maxResults": 6,
        "timeoutMs": 4000
      },
      "paths": [
        {
          "name": "runbooks",
          "path": "__REPO_ROOT__/platform/docs",
          "pattern": "**/*.md"
        },
        {
          "name": "skills",
          "path": "__REPO_ROOT__/platform/skills",
          "pattern": "**/*.md"
        },
        {
          "name": "readme",
          "path": "__REPO_ROOT__",
          "pattern": "README.md"
        },
        {
          "name": "quickstart",
          "path": "__REPO_ROOT__",
          "pattern": "QUICKSTART.md"
        },
        {
          "name": "setup-guide",
          "path": "__REPO_ROOT__",
          "pattern": "SETUP_GUIDE.md"
        },
        {
          "name": "usage-guide",
          "path": "__REPO_ROOT__",
          "pattern": "USAGE_GUIDE.md"
        },
        {
          "name": "project-memory",
          "path": "__REPO_ROOT__",
          "pattern": "memory.md"
        },
        {
          "name": "shared-memory",
          "path": "__REPO_ROOT__/platform/workspace/shared",
          "pattern": "MEMORY.md"
        }
      ],
      "scope": {
        "default": "deny",
        "rules": [
          {
            "action": "allow",
            "match": {
              "chatType": "direct"
            }
          }
        ]
      },
      "searchMode": "search",
      "update": {
        "debounceMs": 15000,
        "interval": "15m",
        "onBoot": true,
        "waitForBootSync": false
      }
    }
  }
}
