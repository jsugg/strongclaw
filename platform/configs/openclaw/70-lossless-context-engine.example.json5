{
  "plugins": {
    "allow": [
      "lossless-claw"
    ],
    "enabled": true,
    "entries": {
      "lossless-claw": {
        "enabled": true
      }
    },
    "load": {
      "paths": [
        "__REPO_ROOT__/vendor/lossless-claw"
      ]
    },
    "slots": {
      "contextEngine": "lossless-claw",
      "memory": "memory-core"
    }
  }
}
