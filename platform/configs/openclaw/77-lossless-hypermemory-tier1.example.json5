{
  "plugins": {
    "allow": [
      "lossless-claw",
      "strongclaw-memory-v2"
    ],
    "enabled": true,
    "entries": {
      "lossless-claw": {
        "enabled": true
      },
      "strongclaw-memory-v2": {
        "enabled": true,
        "config": {
          "command": [
            "clawops"
          ],
          "configPath": "__REPO_ROOT__/platform/configs/memory/memory-v2.tier1.yaml",
          "autoRecall": true,
          "autoReflect": false,
          "recallMaxResults": 3,
          "timeoutMs": 20000
        }
      }
    },
    "load": {
      "paths": [
        "__LOSSLESS_CLAW_PLUGIN_PATH__",
        "__REPO_ROOT__/platform/plugins/strongclaw-memory-v2"
      ]
    },
    "slots": {
      "contextEngine": "lossless-claw",
      "memory": "strongclaw-memory-v2"
    }
  }
}
