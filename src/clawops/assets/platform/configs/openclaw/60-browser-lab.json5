{
  "browser": {
    "defaultProfile": "browserlab",
    "enabled": true,
    "evaluateEnabled": false,
    "profiles": {
      "browserlab": {
        "cdpUrl": "http://127.0.0.1:9222",
        "color": "#0066CC"
      }
    },
    "ssrfPolicy": {
      "allowedHostnames": [
        "github.com",
        "api.github.com",
        "docs.openclaw.ai"
      ],
      "dangerouslyAllowPrivateNetwork": false,
      "hostnameAllowlist": [
        "github.com",
        "docs.openclaw.ai",
        "api.github.com"
      ]
    }
  }
}
