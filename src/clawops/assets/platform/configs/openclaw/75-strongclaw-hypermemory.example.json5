{
  "plugins": {
    "enabled": true,
    "entries": {
      "strongclaw-hypermemory": {
        "enabled": true,
        "config": {
          "command": [
            "clawops"
          ],
          "configPath": "__HYPERMEMORY_SQLITE_CONFIG_PATH__",
          "autoRecall": false,
          "autoReflect": false,
          "recallMaxResults": 3,
          "timeoutMs": 20000
        }
      }
    },
    "load": {
      "paths": [
        "__REPO_ROOT__/platform/plugins/strongclaw-hypermemory"
      ]
    },
    "slots": {
      "memory": "strongclaw-hypermemory"
    }
  }
}
